<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ChipLocator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_orange</item>
        <item name="colorPrimaryVariant">@color/primary_orange_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <item name="colorSecondary">@color/primary_orange</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>

        <item name="android:colorBackground">@color/background_screen</item>
        <item name="android:windowBackground">@color/background_screen</item>

        <item name="android:statusBarColor">@color/primary_orange</item>
        <item name="android:navigationBarColor">@color/background_card</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Стиль для оранжевой шапки экрана -->
    <style name="ChipLocator.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/primary_orange</item>
        <item name="titleTextColor">@color/white</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Стиль для FAB -->
    <style name="ChipLocator.Fab" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/primary_orange</item>
        <item name="tint">@color/white</item>
    </style>

    <style name="ChipLocator.Tab" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>
</resources>