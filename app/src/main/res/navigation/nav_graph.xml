<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mapFragment">

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.chiplocator.app.ui.map.MapFragment"
        android:label="Карта">
        <action
            android:id="@+id/action_map_to_shop_detail"
            app:destination="@id/shopDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/listFragment"
        android:name="com.chiplocator.app.ui.list.ListFragment"
        android:label="Список">
        <action
            android:id="@+id/action_list_to_shop_detail"
            app:destination="@id/shopDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/catalogFragment"
        android:name="com.chiplocator.app.ui.catalog.CatalogFragment"
        android:label="Каталог" />

    <fragment
        android:id="@+id/shopDetailFragment"
        android:name="com.chiplocator.app.ui.detail.ShopDetailFragment"
        android:label="Магазин">
        <argument
            android:name="shopId"
            app:argType="string" />
    </fragment>

</navigation>