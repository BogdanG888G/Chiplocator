<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mapFragment">

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.example.chiplocator.ui.map.MapFragment"
        android:label="Карта">
        <argument
            android:name="filterProductId"
            app:argType="string"
            android:defaultValue="@null"
            app:nullable="true" />

        <action
            android:id="@+id/action_mapFragment_to_shopDetailFragment"
            app:destination="@id/shopDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/listFragment"
        android:name="com.example.chiplocator.ui.list.ListFragment"
        android:label="Список">

        <action
            android:id="@+id/action_listFragment_to_shopDetailFragment"
            app:destination="@id/shopDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/catalogFragment"
        android:name="com.example.chiplocator.ui.catalog.CatalogFragment"
        android:label="Каталог" />

    <fragment
        android:id="@+id/shopDetailFragment"
        android:name="com.example.chiplocator.ui.detail.ShopDetailFragment"
        android:label="Магазин">
        <argument
            android:name="shopId"
            app:argType="string" />
    </fragment>

</navigation>