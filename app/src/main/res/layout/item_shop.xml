<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_rounded"
    android:padding="14dp">

    <ImageView
        android:id="@+id/ivShopPhoto"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_photo_placeholder"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvShopName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:text="Магазин у дома"
        app:layout_constraintTop_toTopOf="@id/ivShopPhoto"
        app:layout_constraintStart_toEndOf="@id/ivShopPhoto"
        app:layout_constraintEnd_toStartOf="@id/badgePromo" />

    <TextView
        android:id="@+id/badgePromo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_badge_promo"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:text="Акция"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/ivShopPhoto"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/badgeNew"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_badge_new"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:text="Новинка"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/badgePromo"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvShopAddress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:text="ул. Ленина, 5"
        app:layout_constraintTop_toBottomOf="@id/tvShopName"
        app:layout_constraintStart_toEndOf="@id/ivShopPhoto"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvDistance"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tvShopAddress"
        app:layout_constraintStart_toEndOf="@id/ivShopPhoto"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRoute"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:text="Маршрут"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="8dp"
        app:backgroundTint="@color/primary_orange"
        app:layout_constraintTop_toBottomOf="@id/ivShopPhoto"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>